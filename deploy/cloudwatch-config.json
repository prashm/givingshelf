{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "cwagent"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/syslog",
            "log_group_name": "/aws/ec2/givingshelf/syslog",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 7
          },
          {
            "file_path": "/home/ubuntu/givingshelf/logs/docker/rails-web.log",
            "log_group_name": "/aws/ec2/givingshelf/rails/web",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 30
          },
          {
            "file_path": "/home/ubuntu/givingshelf/logs/docker/rails-worker.log",
            "log_group_name": "/aws/ec2/givingshelf/rails/worker",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 30
          },
          {
            "file_path": "/home/ubuntu/givingshelf/logs/docker/nginx.log",
            "log_group_name": "/aws/ec2/givingshelf/nginx",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 30
          }
        ]
      }
    }
  },
  "metrics": {
    "namespace": "CWAgent",
    "metrics_collected": {
      "cpu": {
        "measurement": [
          {
            "name": "cpu_usage_idle"
          },
          {
            "name": "cpu_usage_iowait"
          },
          {
            "name": "cpu_usage_user"
          },
          {
            "name": "cpu_usage_system"
          }
        ],
        "totalcpu": false
      },
      "disk": {
        "measurement": [
          {
            "name": "used_percent"
          }
        ],
        "metrics_collection_interval": 60,
        "resources": [
          "/"
        ]
      },
      "diskio": {
        "measurement": [
          "io_time",
          "read_bytes",
          "write_bytes",
          "reads",
          "writes"
        ],
        "metrics_collection_interval": 60
      },
      "mem": {
        "measurement": [
          {
            "name": "mem_used_percent"
          }
        ]
      },
      "netstat": {
        "measurement": [
          {
            "name": "tcp_established"
          },
          {
            "name": "tcp_time_wait"
          }
        ]
      },
      "processes": {
        "measurement": [
          {
            "name": "running"
          },
          {
            "name": "sleeping"
          }
        ]
      }
    }
  }
}