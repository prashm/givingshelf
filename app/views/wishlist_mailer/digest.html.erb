<table width="100%" cellpadding="0" cellspacing="0" style="max-width:600px;font-family:Arial,sans-serif">
  <tr>
    <td style="padding:16px 0;font-size:18px;font-weight:bold">Community Wishlist</td>
  </tr>
  <tr>
    <td style="padding:0 0 12px 0;color:#111827;font-size:14px;line-height:1.5;">
      Hi <%= @user.display_name %>,
    </td>
  </tr>
  <tr>
    <td style="padding:0 0 16px 0;color:#374151;font-size:14px;line-height:1.5;">
      These wishlist posts mean someone is looking for an item and hasn&apos;t found one yet. If you have one to share, you can fulfill the wish and start chatting to coordinate pickup.
    </td>
  </tr>
  <% Array(@entries).each do |entry| %>
    <% e = entry.with_indifferent_access %>
    <% it = e[:item] %>
    <% req = e[:requester] %>
    <tr>
      <td style="border:1px solid #e5e7eb;border-radius:8px;padding:12px;margin-bottom:12px">
        <table width="100%">
          <tr>
            <td width="80" valign="top">
              <% if it.cover_image.attached? %>
                <img src="<%= it.cover_image.attachment.url %>" width="72" style="display:block;border-radius:4px" alt="" />
              <% end %>
            </td>
            <td valign="top" style="padding-left:8px">
              <div style="font-weight:bold"><%= it.title %></div>
              <div style="color:#6b7280;font-size:14px"><%= it.type.capitalize %> requested by <%= req&.display_name || "a neighbor" %></div>
            </td>
          </tr>
        </table>
        <p style="margin:12px 0 0 0">
          <a href="<%= root_url %>fulfill_wishlist/<%= it.id %>" style="background:#059669;color:#fff;padding:10px 16px;border-radius:6px;text-decoration:none;display:inline-block">Fulfill this wish</a>
        </p>
      </td>
    </tr>
    <tr>
      <td style="height:12px;line-height:12px;font-size:0">&nbsp;</td>
    </tr>
  <% end %>
</table>
