<div class="container mx-auto py-8 px-4 max-w-4xl">
  <div class="mb-6">
    <h1 class="text-2xl font-bold">My Community Groups</h1>
  </div>
  
  <% if flash[:alert] %>
    <div class="bg-red-50 border border-red-200 rounded-md p-3 mb-4">
      <p class="text-red-600 text-sm"><%= flash[:alert] %></p>
    </div>
  <% end %>
  
  <% if flash[:notice] %>
    <div class="bg-green-50 border border-green-200 rounded-md p-3 mb-4">
      <p class="text-green-600 text-sm"><%= flash[:notice] %></p>
    </div>
  <% end %>
  
  <div class="bg-white rounded-lg shadow-md p-6 mb-6">
      <h2 class="text-xl font-semibold mb-4">Create New Group</h2>
      <%= form_with model: CommunityGroup.new, url: group_admin_index_path, method: :post, local: true do |form| %>
        <%= render "group_form_fields", form: form %>
        <%= form.submit "Create Group", class: "bg-emerald-600 text-white px-4 py-2 rounded-md hover:bg-emerald-700" %>
      <% end %>
    </div>
    
    <% if @groups && @groups.any? %>
      <div class="space-y-4">
        <% @groups.each do |group| %>
        <div class="bg-white rounded-lg shadow-md p-6">
          <div class="flex justify-between items-start mb-4">
            <div>
              <h3 class="text-xl font-semibold"><%= group.name %></h3>
              <% if group.group_description.present? %>
                <p class="text-gray-600"><%= group.group_description %></p>
              <% end %>
              <p class="text-sm text-gray-500">
                Url: <%= link_to "/g/#{group.short_name}", "/g/#{group.short_name}", class: "text-emerald-600 hover:text-emerald-700 underline" %>
                <%= group.domain.present? ? " | Email Domain: #{group.domain}" : "" %> 
              </p>
              <div class="mt-2 flex items-center gap-3 text-sm">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= group.public? ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-800" %>">
                  <%= group.public? ? "Public" : "Private" %>
                </span>
                <%= link_to "#{group.community_group_memberships.size} members", group_admin_memberships_path(group), class: "text-emerald-600 hover:text-emerald-700 underline" %>
              </div>
            </div>
            <div class="flex gap-2">
              <%= link_to "Edit", group_admin_path(group), class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700" %>
              <%= button_to "Delete", group_admin_path(group), method: :delete, class: "bg-red-600 text-white px-4 py-2 rounded-md hover:bg-red-700", form: { data: { turbo_confirm: "Are you sure you want to delete this group and all its memberships? This action cannot be undone." } } %>
            </div>
          </div>
          
          <% if group.sub_groups.any? %>
            <div class="mt-4">
              <h4 class="font-medium mb-2">Sub Groups:</h4>
              <ul class="list-disc list-inside">
                <% group.sub_groups.each do |sg| %>
                  <li><%= sg.name %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-lg shadow-md p-6">
        <p class="text-gray-600 text-center">You don't have any groups yet. Create your first group above.</p>
      </div>
    <% end %>
</div>
