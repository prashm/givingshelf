<div class="container mx-auto py-8 px-4 max-w-4xl">
  <div class="mb-6">
    <%= link_to "← Back to Groups", group_admin_index_path, class: "text-emerald-600 hover:text-emerald-700" %>
  </div>
  
  <h1 class="text-2xl font-bold mb-6">Edit Group: <%= @group.name %></h1>
  
  <% if flash[:alert] %>
    <div class="bg-red-50 border border-red-200 rounded-md p-3 mb-4">
      <p class="text-red-600 text-sm"><%= flash[:alert] %></p>
    </div>
  <% end %>
  
  <% if flash[:notice] %>
    <div class="bg-green-50 border border-green-200 rounded-md p-3 mb-4">
      <p class="text-green-600 text-sm"><%= flash[:notice] %></p>
    </div>
  <% end %>
  
  <div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4">Group Information</h2>
    <%= form_with url: group_admin_group_path(@group), method: :patch, local: true do |form| %>
      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <%= form.label :name, "Group Name *", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field "community_group[name]", required: true, value: @group.name, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
        </div>
        <div>
          <%= form.label "community_group[group_type]", "Group Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field "community_group[group_type]", value: @group.group_type, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
        </div>
        <div>
          <%= form.label "community_group[domain]", "Domain *", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field "community_group[domain]", required: true, value: @group.domain, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
        </div>
        <div>
          <%= form.label "community_group[short_name]", "Short Name *", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field "community_group[short_name]", required: true, value: @group.short_name, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
        </div>
      </div>
      <%= form.submit "Update Group", class: "bg-emerald-600 text-white px-4 py-2 rounded-md hover:bg-emerald-700" %>
    <% end %>
  </div>
  
  <div class="bg-white rounded-lg shadow-md p-6">
    <h2 class="text-xl font-semibold mb-4">Sub Groups</h2>
    
    <% if @group.sub_groups.any? %>
      <ul class="mb-4 space-y-2">
        <% @group.sub_groups.each do |sg| %>
          <li class="flex justify-between items-center p-3 bg-gray-50 rounded-md">
            <span><%= sg.name %></span>
            <%= button_to "Delete", group_admin_sub_group_path(@group, sub_group_id: sg.id), method: :delete, class: "bg-red-600 text-white px-3 py-1 rounded-md hover:bg-red-700 text-sm", data: { confirm: "Are you sure?" } %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-gray-600 mb-4">No sub groups yet.</p>
    <% end %>
    
    <%= form_with url: group_admin_sub_groups_path(@group), method: :post, local: true do |form| %>
      <div class="flex gap-2">
        <%= form.text_field :name, placeholder: "Sub group name", required: true, class: "flex-1 px-3 py-2 border border-gray-300 rounded-md" %>
        <%= form.submit "Add Sub Group", class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700" %>
      </div>
    <% end %>
  </div>
</div>

