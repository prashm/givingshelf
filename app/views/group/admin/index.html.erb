<div class="container mx-auto py-8 px-4 max-w-4xl">
  <div class="mb-6 flex justify-between items-center">
    <h1 class="text-2xl font-bold">My Community Groups</h1>
    <%= button_to "Logout", group_admin_logout_path, method: :delete, class: "bg-gray-600 text-white px-4 py-2 rounded-md hover:bg-gray-700" %>
  </div>
  
  <% if flash[:alert] %>
    <div class="bg-red-50 border border-red-200 rounded-md p-3 mb-4">
      <p class="text-red-600 text-sm"><%= flash[:alert] %></p>
    </div>
  <% end %>
  
  <% if flash[:notice] %>
    <div class="bg-green-50 border border-green-200 rounded-md p-3 mb-4">
      <p class="text-green-600 text-sm"><%= flash[:notice] %></p>
    </div>
  <% end %>
  
  <div class="bg-white rounded-lg shadow-md p-6 mb-6">
      <h2 class="text-xl font-semibold mb-4">Create New Group</h2>
      <%= form_with url: group_admin_index_path, method: :post, local: true do |form| %>
        <div class="grid grid-cols-2 gap-4 mb-4">
          <div>
            <%= form.label :name, "Group Name *", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field "community_group[name]", required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
          </div>
          <div>
            <%= form.label "community_group[group_type]", "Group Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field "community_group[group_type]", class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
          </div>
          <div>
            <%= form.label "community_group[domain]", "Domain *", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field "community_group[domain]", required: true, placeholder: "example.com", class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
          </div>
          <div>
            <%= form.label "community_group[short_name]", "Short Name *", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field "community_group[short_name]", required: true, placeholder: "example", class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
          </div>
        </div>
        <%= form.submit "Create Group", class: "bg-emerald-600 text-white px-4 py-2 rounded-md hover:bg-emerald-700" %>
      <% end %>
    </div>
    
    <% if @groups && @groups.any? %>
      <div class="space-y-4">
        <% @groups.each do |group| %>
        <div class="bg-white rounded-lg shadow-md p-6">
          <div class="flex justify-between items-start mb-4">
            <div>
              <h3 class="text-xl font-semibold"><%= group.name %></h3>
              <% if group.group_type.present? %>
                <p class="text-gray-600"><%= group.group_type %></p>
              <% end %>
              <p class="text-sm text-gray-500">Domain: <%= group.domain %> | Short Name: <%= group.short_name %></p>
            </div>
            <div class="flex gap-2">
              <%= link_to "Edit", group_admin_group_path(group), class: "bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700" %>
              <%= button_to "Delete", group_admin_group_delete_path(group), method: :delete, class: "bg-red-600 text-white px-4 py-2 rounded-md hover:bg-red-700", form: { data: { turbo_confirm: "Are you sure you want to delete this group and all its memberships? This action cannot be undone." } } %>
            </div>
          </div>
          
          <% if group.sub_groups.any? %>
            <div class="mt-4">
              <h4 class="font-medium mb-2">Sub Groups:</h4>
              <ul class="list-disc list-inside">
                <% group.sub_groups.each do |sg| %>
                  <li><%= sg.name %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-lg shadow-md p-6">
        <p class="text-gray-600 text-center">You don't have any groups yet. Create your first group above.</p>
      </div>
    <% end %>
</div>

