<div class="container mx-auto py-8 px-4 max-w-5xl">
  <div class="mb-6">
    <div>
      <%= link_to "← Back to Groups", group_admin_index_path, class: "text-emerald-600 hover:text-emerald-700" %>
      <h1 class="text-2xl font-bold mt-2">Manage Memberships: <%= @group.name %></h1>
      <p class="text-sm text-gray-600">
        <span class="font-medium">Created:</span> <%= @group.created_at.to_date %>
        <span class="mx-2">•</span>
        <span class="font-medium">Members:</span> <%= @member_count %>
        <span class="mx-2">•</span>
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= @group.public? ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-800" %>">
          <%= @group.public? ? "Public" : "Private" %>
        </span>
      </p>
    </div>
  </div>

  <% if flash[:alert] %>
    <div class="bg-red-50 border border-red-200 rounded-md p-3 mb-4">
      <p class="text-red-600 text-sm"><%= flash[:alert] %></p>
    </div>
  <% end %>

  <% if flash[:notice] %>
    <div class="bg-green-50 border border-green-200 rounded-md p-3 mb-4">
      <p class="text-green-600 text-sm"><%= flash[:notice] %></p>
    </div>
  <% end %>

  <div class="bg-white rounded-lg shadow-md p-6">
    <div class="border-b mb-6">
      <nav class="-mb-px flex gap-6">
        <%= link_to "Current (#{@current_memberships.size})", group_admin_memberships_path(@group, tab: "current"), class: "py-2 border-b-2 text-sm font-medium #{ @tab == "current" ? "border-emerald-600 text-emerald-700" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300" }" %>
        <%= link_to "Requested (#{@requested_requests.size})", group_admin_memberships_path(@group, tab: "requested"), class: "py-2 border-b-2 text-sm font-medium #{ @tab == "requested" ? "border-emerald-600 text-emerald-700" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300" }" %>
        <%= link_to "Invites (#{@invited_requests.size})", group_admin_memberships_path(@group, tab: "invites"), class: "py-2 border-b-2 text-sm font-medium #{ @tab == "invites" ? "border-emerald-600 text-emerald-700" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300" }" %>
      </nav>
    </div>

    <% if @tab == "current" %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Member</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Joined</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Admin</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @current_memberships.each do |membership| %>
              <tr>
                <td class="px-4 py-3">
                  <div class="font-medium text-gray-900"><%= membership.user.display_name %></div>
                  <div class="text-sm text-gray-500"><%= membership.user.email_address %></div>
                </td>
                <td class="px-4 py-3 text-sm text-gray-700"><%= membership.created_at.to_date %></td>
                <td class="px-4 py-3">
                  <% if membership.admin? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800">Admin</span>
                  <% else %>
                    <span class="text-sm text-gray-500">No</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-right">
                  <details class="inline-block text-left">
                    <summary class="cursor-pointer select-none inline-flex items-center justify-center w-9 h-9 rounded-md hover:bg-gray-100">
                      ⋯
                    </summary>
                    <div class="absolute mt-2 w-48 bg-white border border-gray-200 rounded-md shadow-lg p-1 z-10">
                      <% if membership.admin? %>
                        <%= form_with url: demote_group_admin_membership_path(@group, membership_id: membership.id), method: :post, local: true, class: "m-0", data: { turbo_confirm: "Revoke admin privileges for this member?" } do |form| %>
                          <%= form.button type: :submit, class: "flex items-center w-full text-left px-3 py-2 text-sm hover:bg-gray-50 rounded text-gray-700" do %>
                            <svg class="w-4 h-4 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                            </svg>
                            <span>Revoke Admin</span>
                          <% end %>
                        <% end %>
                      <% else %>
                        <%= form_with url: promote_group_admin_membership_path(@group, membership_id: membership.id), method: :post, local: true, class: "m-0", data: { turbo_confirm: "Make this member an admin?" } do |form| %>
                          <%= form.button type: :submit, class: "flex items-center w-full text-left px-3 py-2 text-sm hover:bg-gray-50 rounded text-gray-700" do %>
                            <svg class="w-4 h-4 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                            </svg>
                            <span>Make Admin</span>
                          <% end %>
                        <% end %>
                      <% end %>
                      <%= form_with url: revoke_group_admin_membership_path(@group, membership_id: membership.id), method: :delete, local: true, class: "m-0", data: { turbo_confirm: "Revoke membership for this user? This cannot be undone." } do |form| %>
                        <%= form.button type: :submit, class: "flex items-center w-full text-left px-3 py-2 text-sm text-red-700 hover:bg-red-50 rounded" do %>
                          <svg class="w-4 h-4 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
                          </svg>
                          <span>Revoke Membership</span>
                        <% end %>
                      <% end %>
                    </div>
                  </details>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% elsif @tab == "requested" %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Trust</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Requested</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Message</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @requested_requests.each do |req| %>
              <tr>
                <td class="px-4 py-3">
                  <div class="font-medium text-gray-900"><%= req.requester&.display_name || "Unknown" %></div>
                  <div class="text-sm text-gray-500"><%= req.requester&.email_address %></div>
                </td>
                <td class="px-4 py-3 text-sm text-gray-700"><%= req.requester&.trust_score %></td>
                <td class="px-4 py-3 text-sm text-gray-700"><%= req.created_at.to_date %></td>
                <td class="px-4 py-3 text-sm text-gray-700"><%= req.message.presence || "-" %></td>
                <td class="px-4 py-3 text-right">
                  <div class="flex justify-end gap-2">
                    <%= button_to "Accept", accept_group_admin_membership_request_path(@group, request_id: req.id), method: :post, class: "bg-emerald-600 text-white px-3 py-1 rounded-md hover:bg-emerald-700 text-sm", form: { data: { turbo_confirm: "Accept this request and add the user to the group?" } } %>
                    <%= button_to "Reject", reject_group_admin_membership_request_path(@group, request_id: req.id), method: :post, class: "bg-red-600 text-white px-3 py-1 rounded-md hover:bg-red-700 text-sm", form: { data: { turbo_confirm: "Reject this request?" } } %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <% if @requested_requests.empty? %>
          <p class="text-gray-600 text-sm mt-4">No pending join requests.</p>
        <% end %>
      </div>
    <% else %>
      <div class="mb-6">
        <h3 class="text-lg font-semibold mb-3">Send an invite</h3>
        <%= form_with url: invite_group_admin_membership_requests_path(@group), method: :post, local: true do |form| %>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3 items-end">
            <div>
              <%= label_tag :email_address, "Email *", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= text_field_tag :email_address, nil, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md", placeholder: "user@example.com" %>
            </div>
            <div class="md:col-span-2">
              <%= label_tag :message, "Message (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= text_field_tag :message, nil, class: "w-full px-3 py-2 border border-gray-300 rounded-md", placeholder: "Add a note for the invite email..." %>
            </div>
          </div>
          <div class="mt-3">
            <%= form.submit "Send Invite", class: "bg-emerald-600 text-white px-4 py-2 rounded-md hover:bg-emerald-700" %>
          </div>
        <% end %>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Sent</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Message</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @invited_requests.each do |inv| %>
              <tr>
                <td class="px-4 py-3 text-sm text-gray-900"><%= inv.email_address %></td>
                <td class="px-4 py-3 text-sm text-gray-700"><%= inv.created_at.to_date %></td>
                <td class="px-4 py-3 text-sm text-gray-700"><%= inv.message.presence || "-" %></td>
                <td class="px-4 py-3 text-right">
                  <%= button_to "Revoke", revoke_invite_group_admin_membership_request_path(@group, request_id: inv.id), method: :post, class: "bg-red-600 text-white px-3 py-1 rounded-md hover:bg-red-700 text-sm", form: { data: { turbo_confirm: "Revoke this invite?" } } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <% if @invited_requests.empty? %>
          <p class="text-gray-600 text-sm mt-4">No pending invites.</p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
