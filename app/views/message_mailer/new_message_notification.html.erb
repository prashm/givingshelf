<!DOCTYPE html>
<html>
  <head>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
  </head>
  <body>
    <% item_type = @item.type.downcase %>
    <% item_description = @item.is_a?(Book) ? "#{@item.title} by #{@item.author}" : "#{@item.title} (#{@item.brand})" %>
    <h2>New Message About Your <%= item_type.capitalize %> Request</h2>
    <p>Hello <%= @recipient.display_name %>,</p>
    
    <p><%= @sender.display_name %> sent you a new message about the <%= item_type %> request for "<%= item_description %>".</p>
    
    <h3>Message Preview:</h3>
    <p><%= @message.content.truncate(100) %></p>
    
    <p><strong>View the full message and continue the conversation:</strong></p>
    <p>
      <a href="<%= "#{Rails.application.config.action_mailer.default_url_options[:host]}/item_request_details?id=#{@item_request.id}" %>" 
         style="background-color: #10b981; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; display: inline-block;">
        View <%= item_type.capitalize %> Request Details
      </a>
    </p>
    
  </body>
</html>

