<!DOCTYPE html>
<html>
  <head>
    <title>Admin - GivingShelf</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/gs-icon.png" type="image/png">
    <%= stylesheet_link_tag "application-bundled", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags "admin_app" %>
    <style>
      * {
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        background: #f5f5f5;
        margin: 0;
        padding: 0;
        line-height: 1.6;
        color: #333;
      }
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
      }
      h1, h2, h3 {
        margin-top: 0;
        color: #1a1a1a;
      }
      h1 {
        font-size: 2rem;
      }
      h2 {
        font-size: 1.5rem;
      }
      h3 {
        font-size: 1.25rem;
      }
      a {
        color: #059669;
        text-decoration: none;
      }
      a:hover {
        color: #047857;
        text-decoration: underline;
      }
      .bg-white {
        background: white;
      }
      .rounded-lg {
        border-radius: 0.5rem;
      }
      .shadow-md {
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
      }
      .p-6 {
        padding: 1.5rem;
      }
      .mb-4 {
        margin-bottom: 1rem;
      }
      .mb-6 {
        margin-bottom: 1.5rem;
      }
      .mb-8 {
        margin-bottom: 2rem;
      }
      .mt-4 {
        margin-top: 1rem;
      }
      input[type="text"],
      input[type="email"],
      input[type="password"],
      select {
        width: 100%;
        padding: 0.5rem 0.75rem;
        border: 1px solid #d1d5db;
        border-radius: 0.375rem;
        font-size: 1rem;
      }
      input[type="text"]:focus,
      input[type="email"]:focus,
      input[type="password"]:focus,
      select:focus {
        outline: none;
        border-color: #059669;
        box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.1);
      }
      button,
      input[type="submit"],
      .btn {
        padding: 0.5rem 1rem;
        border: none;
        border-radius: 0.375rem;
        font-size: 1rem;
        cursor: pointer;
        display: inline-block;
        text-decoration: none;
        text-align: center;
        transition: background-color 0.2s;
      }
      button:hover,
      input[type="submit"]:hover,
      .btn:hover {
        opacity: 0.9;
      }
      .bg-emerald-600 {
        background-color: #059669;
        color: white;
      }
      .bg-emerald-600:hover {
        background-color: #047857;
      }
      .bg-blue-600 {
        background-color: #2563eb;
        color: white;
      }
      .bg-blue-600:hover {
        background-color: #1d4ed8;
      }
      .bg-red-600 {
        background-color: #dc2626;
        color: white;
      }
      .bg-red-600:hover {
        background-color: #b91c1c;
      }
      .bg-gray-600 {
        background-color: #4b5563;
        color: white;
      }
      .bg-gray-600:hover {
        background-color: #374151;
      }
      .text-center {
        text-align: center;
      }
      .flex {
        display: flex;
      }
      .justify-between {
        justify-content: space-between;
      }
      .items-center {
        align-items: center;
      }
      .items-start {
        align-items: flex-start;
      }
      .gap-2 {
        gap: 0.5rem;
      }
      .gap-4 {
        gap: 1rem;
      }
      .grid {
        display: grid;
      }
      .grid-cols-2 {
        grid-template-columns: repeat(2, 1fr);
      }
      .space-y-2 > * + * {
        margin-top: 0.5rem;
      }
      .space-y-4 > * + * {
        margin-top: 1rem;
      }
      label {
        display: block;
        font-weight: 500;
        margin-bottom: 0.5rem;
        color: #374151;
      }
      .text-sm {
        font-size: 0.875rem;
      }
      .text-gray-600 {
        color: #4b5563;
      }
      .text-gray-500 {
        color: #6b7280;
      }
      .text-red-600 {
        color: #dc2626;
      }
      .text-green-600 {
        color: #16a34a;
      }
      .bg-red-50 {
        background-color: #fef2f2;
      }
      .bg-green-50 {
        background-color: #f0fdf4;
      }
      .border-red-200 {
        border-color: #fecaca;
      }
      .border-green-200 {
        border-color: #bbf7d0;
      }
      .border {
        border-width: 1px;
        border-style: solid;
      }
      .rounded-md {
        border-radius: 0.375rem;
      }
      .list-disc {
        list-style-type: disc;
      }
      .list-inside {
        list-style-position: inside;
      }
      .max-w-4xl {
        max-width: 56rem;
      }
      .max-w-md {
        max-width: 28rem;
      }
      @media (max-width: 768px) {
        .grid-cols-2 {
          grid-template-columns: 1fr;
        }
        .container {
          padding: 1rem;
        }
      }

      /* Admin layout chrome (navbar + footer) */
      .admin-shell {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .admin-main {
        flex: 1;
      }
      /* Navbar matches root page (Navbar.js) */
      .admin-navbar {
        background-color: #059669;
        color: #fff;
        height: 4rem;
        width: 100%;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
      }
      .admin-navbar-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 100%;
        width: 100%;
      }
      .admin-navbar-brand {
        display: flex;
        align-items: center;
        height: 100%;
        cursor: pointer;
        user-select: none;
      }
      .admin-navbar-logo-wrap {
        background: #fff;
        height: 100%;
        max-height: 4rem;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.375rem 0.5rem;
      }
      .admin-navbar-logo-wrap img {
        height: 100%;
        width: auto;
        max-width: 12rem;
        object-fit: contain;
        object-position: center;
      }
      .admin-navbar-right {
        margin-right: 1rem;
      }
      .admin-navbar-logout {
        color: #fff;
        text-decoration: none;
        cursor: pointer;
      }
      .admin-navbar-logout:hover {
        text-decoration: underline;
      }
      .admin-footer {
        background: #111827;
        color: #9ca3af;
        text-align: center;
        padding: 1.75rem 1rem;
        font-size: 0.95rem;
      }
      .admin-footer-version {
        margin-top: 0.4rem;
        font-size: 0.9rem;
        color: #9ca3af;
      }
    </style>
  </head>
  <body class="admin-shell">
    <header class="admin-navbar">
      <div class="admin-navbar-inner">
        <div class="admin-navbar-brand" onclick="window.location='/'">
          <div class="admin-navbar-logo-wrap">
            <img src="/gs-logo.png" alt="GivingShelf" />
          </div>
        </div>

        <div class="admin-navbar-right">
          <% if controller_path.start_with?("group/") && authenticated? && Current.user&.group_admin? %>
            <%= link_to "Logout", group_admin_logout_path, data: { turbo_method: :delete }, class: "admin-navbar-logout" %>
          <% end %>
        </div>
      </div>
    </header>

    <main class="admin-main">
      <%= yield %>
    </main>

    <footer class="admin-footer">
      <div>© <%= GivingShelf::Version.copyright_year %> <%= GivingShelf::Version::COMPANY_NAME %>. All rights reserved.</div>
      <div class="admin-footer-version">Version <%= GivingShelf::Version::APP_VERSION %></div>
    </footer>
  </body>
</html>

