<!DOCTYPE html>
<html lang="en">
  <head>
    <% 
      # Normalize canonical URL - always use HTTPS and non-www
      def normalize_canonical_url(url)
        return url if url.blank?
        # Replace http:// with https://
        url = url.gsub(/^http:\/\//, 'https://')
        # Remove www subdomain
        url = url.gsub(/^https:\/\/www\./, 'https://')
        # For query parameters (like ?search=), use base URL
        if url.include?('?search=')
          return "https://booksharecommunity.org/"
        end
        url
      end
      
      # If this is a book detail page, use book-specific meta tags
      if defined?(@book) && @book.present?
        page_title = content_for(:title) || "#{@book.title} by #{@book.author} - BookShare Community"
        page_description = content_for(:description) || @book.summary
        page_url = content_for(:url) || "#{request.protocol}#{request.host}/books/#{@book.id}"
        # Use book cover image if available, otherwise default
        if @book.cover_image.attached?
          page_image = content_for(:image) || rails_blob_url(@book.cover_image, only_path: false)
        else
          page_image = content_for(:image) || "https://booksharecommunity.org/bsc-icon.png"
        end
        canonical_url = content_for(:canonical) || "https://booksharecommunity.org/books/#{@book.id}"
      else
        page_title = content_for(:title) || "Donate Books for Free | BookShare Community - Share. Discover. Connect."
        page_description = content_for(:description) || "Donate books for free in your local community. BookShare Community helps you donate used books, discover free books from neighbors, and share the joy of reading. 100% free book donation and sharing platform."
        # Normalize page_url to always use HTTPS and non-www, and remove query params for canonical
        current_url = request.url
        # Remove query parameters for canonical URL
        canonical_url = content_for(:canonical) || normalize_canonical_url(current_url.split('?').first)
        page_url = content_for(:url) || normalize_canonical_url(current_url)
        page_image = content_for(:image) || "https://booksharecommunity.org/bsc-icon.png"
      end
      base_url = "https://booksharecommunity.org"
    %>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= page_description %>">
    
    <%# Canonical URL %>
    <link rel="canonical" href="<%= canonical_url %>">
    
    <%# Open Graph meta tags %>
    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= page_title %>">
    <meta property="og:description" content="<%= page_description %>">
    <meta property="og:url" content="<%= page_url %>">
    <meta property="og:image" content="<%= page_image %>">
    <meta property="og:site_name" content="BookShare Community">
    
    <%# Twitter Card meta tags %>
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= page_title %>">
    <meta name="twitter:description" content="<%= page_description %>">
    <meta name="twitter:image" content="<%= page_image %>">
    <% if ENV['SENTRY_DSN_FRONTEND'].present? %>
      <meta name="sentry-dsn" content="<%= ENV['SENTRY_DSN_FRONTEND'] %>">
      <meta name="sentry-environment" content="<%= Rails.env %>">
      <% if ENV['SENTRY_RELEASE'].present? %>
        <meta name="sentry-release" content="<%= ENV['SENTRY_RELEASE'] %>">
      <% end %>
    <% end %>
    <% if ENV['CLOUDFLARE_TURNSTILE_SITE_KEY'].present? && (Rails.env.production? || Rails.env.staging?) %>
      <meta name="turnstile-site-key" content="<%= ENV['CLOUDFLARE_TURNSTILE_SITE_KEY'] %>">
    <% end %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/bsc-icon.png" type="image/png">
    <link rel="icon" href="/bsc-icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/bsc-icon.png">

    <%# Structured Data (JSON-LD) %>
    <script type="application/ld+json">
    <%
      structured_data = {
        "@context" => "https://schema.org",
        "@graph" => [
          {
            "@type" => "Organization",
            "name" => "BookShare Community",
            "url" => base_url,
            "logo" => "#{base_url}/bsc-icon.png",
            "description" => "A community platform for sharing and discovering books. Donate used books and find great reads from neighbors.",
            "sameAs" => []
          }
        ]
      }

      # Add Book schema if this is a book detail page
      if defined?(@book) && @book.present?
        cover_image_url = @book.cover_image.attached? ? @book.cover_image.attachment.url : nil
        
        # Convert to Schema.org Book format
        book_data = {
          "@type" => "Book",
          "name" => @book.title,
          "author" => {
            "@type" => "Person",
            "name" => @book.author
          },
          "description" => @book.summary,
          "genre" => @book.genre,
          "datePublished" => @book.published_year.to_s,
          "url" => page_url,
          "isbn" => @book.isbn
        }
        if cover_image_url.present?
          book_data["image"] = cover_image_url
        end
        structured_data["@graph"] << book_data
      end

      # Add WebSite schema
      structured_data["@graph"] << {
        "@type" => "WebSite",
        "name" => "BookShare Community",
        "url" => base_url,
        "description" => page_description
      }
      
      # Add Service schema for book donation (only for homepage)
      if !defined?(@book) || @book.blank?
        structured_data["@graph"] << {
          "@type" => "Service",
          "name" => "Book Donation and Sharing Service",
          "description" => "Free book donation and sharing service for local communities. Donate books, discover free books, and share books with neighbors.",
          "provider" => {
            "@type" => "Organization",
            "name" => "BookShare Community"
          },
          "areaServed" => {
            "@type" => "Country",
            "name" => "United States"
          },
          "serviceType" => "Book Donation and Sharing",
          "url" => base_url
        }
      end
    %>
    <%= structured_data.to_json.html_safe %>
    </script>

    <%= stylesheet_link_tag "application-bundled", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application-webpack", "data-turbo-track": "reload" %>
    <%# NOTE: This app’s JS is bundled by webpack into app/assets/javascripts/application-webpack.js.
        We intentionally do not load importmap here to avoid double-loading "application". %>
  </head>

  <body>
    <div id="root"></div>
  </body>
</html>
