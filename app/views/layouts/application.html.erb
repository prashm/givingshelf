<!DOCTYPE html>
<html lang="en">
  <head>
    <% 
      # Normalize canonical URL - always use HTTPS and non-www
      def normalize_canonical_url(url)
        return url if url.blank?
        # Replace http:// with https://
        url = url.gsub(/^http:\/\//, 'https://')
        # Remove www subdomain
        url = url.gsub(/^https:\/\/www\./, 'https://')
        # For query parameters (like ?search=), use base URL
        if url.include?('?search=')
          return "https://givingshelf.net/"
        end
        url
      end
      
      # If this is an item detail page (book or toy), use item-specific meta tags
      if defined?(@item) && @item.present?
        is_book = @item.is_a?(Book)
        item_path = is_book ? "books/#{@item.id}" : "toys/#{@item.id}"
        page_title = content_for(:title) || (
          is_book ? "#{@item.title} by #{@item.author} - GivingShelf" : "#{@item.title} - Free Toy | GivingShelf"
        )
        page_description = content_for(:description) || @item.summary
        page_url = content_for(:url) || "#{request.protocol}#{request.host}/#{item_path}"
        if @item.cover_image.attached?
          page_image = content_for(:image) || @item.cover_image.attachment.url
        else
          page_image = content_for(:image) || "https://givingshelf.net/gs-logo.png"
        end
        canonical_url = content_for(:canonical) || "https://givingshelf.net/#{item_path}"
      else
        page_title = content_for(:title) || "GivingShelf | Local Community Book & Toy Sharing"
        page_description = content_for(:description) || "A free platform for neighbors to share, swap, and donate books and toys. Join your local GivingShelf community to reduce waste and support local families."
        # Normalize page_url to always use HTTPS and non-www, and remove query params for canonical
        current_url = request.url
        # Remove query parameters for canonical URL
        canonical_url = content_for(:canonical) || normalize_canonical_url(current_url.split('?').first)
        page_url = content_for(:url) || normalize_canonical_url(current_url)
        page_image = content_for(:image) || "https://givingshelf.net/gs-logo.png"
      end
      base_url = "https://givingshelf.net"
    %>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= page_description %>">
    <meta name="keywords" content="book swap, toy donation, community sharing, local neighborhood, free books, sustainable living">
    <meta name="classification" content="Non-Profit, Community, Education">
    <meta name="category" content="Online Communities">
    <%# Canonical URL %>
    <link rel="canonical" href="<%= canonical_url %>">
    
    <%# Open Graph meta tags %>
    <meta property="og:type" content="website">
    <meta property="og:title" content="GivingShelf - Share Locally, Give Freely">
    <meta property="og:description" content="The easiest way to find and share free books and toys in your neighborhood.">
    <meta property="og:url" content="<%= page_url %>">
    <meta property="og:image" content="<%= page_image %>">
    <meta property="og:site_name" content="GivingShelf">
    
    <%# Twitter Card meta tags %>
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= page_title %>">
    <meta name="twitter:description" content="<%= page_description %>">
    <meta name="twitter:image" content="<%= page_image %>">
    <% if ENV['SENTRY_DSN_FRONTEND'].present? %>
      <meta name="sentry-dsn" content="<%= ENV['SENTRY_DSN_FRONTEND'] %>">
      <meta name="sentry-environment" content="<%= Rails.env %>">
      <% if ENV['SENTRY_RELEASE'].present? %>
        <meta name="sentry-release" content="<%= ENV['SENTRY_RELEASE'] %>">
      <% end %>
    <% end %>
    <% if ENV['CLOUDFLARE_TURNSTILE_SITE_KEY'].present? && (Rails.env.production? || Rails.env.staging?) %>
      <meta name="turnstile-site-key" content="<%= ENV['CLOUDFLARE_TURNSTILE_SITE_KEY'] %>">
    <% end %>
    <% if ENV['GOOGLE_BOOKS_API_KEY'].present? %>
      <meta name="google-books-api-key" content="<%= ENV['GOOGLE_BOOKS_API_KEY'] %>">
    <% end %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/gs-icon.svg" type="image/svg+xml">
    <link rel="icon" href="/gs-icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/gs-icon.png">

    <%# Structured Data (JSON-LD) %>
    <script type="application/ld+json">
    <%
      structured_data = {
        "@context" => "https://schema.org",
        "@graph" => [
          {
            "@type" => "NGO",
            "@id" => "https://givingshelf.net/#organization",
            "name" => "GivingShelf",
            "url" => base_url,
            "logo" => "#{base_url}/gs-logo.png",
            "description" => "A community-driven platform for local book and toy sharing.",
            "sameAs" => []
          }
        ]
      }

      # Add item schema for book or toy detail pages
      if defined?(@item) && @item.present?
        cover_image_url = @item.cover_image.attached? ? @item.cover_image.attachment.url : nil
        is_book = @item.is_a?(Book)

        if is_book
          book_data = {
            "@type" => "Book",
            "name" => @item.title,
            "author" => { "@type" => "Person", "name" => @item.author },
            "description" => @item.summary,
            "genre" => @item.genre,
            "datePublished" => @item.published_year.to_s,
            "url" => page_url,
            "isbn" => @item.isbn
          }
          book_data["image"] = cover_image_url if cover_image_url.present?
          structured_data["@graph"] << book_data
        else
          toy_data = {
            "@type" => "Product",
            "name" => @item.title,
            "description" => @item.summary,
            "url" => page_url
          }
          toy_data["brand"] = { "@type" => "Brand", "name" => @item.brand } if @item.brand.present?
          toy_data["image"] = cover_image_url if cover_image_url.present?
          structured_data["@graph"] << toy_data
        end
      end

      # Add WebSite schema
      structured_data["@graph"] << {
        "@type" => "WebSite",
        "@id" => "https://givingshelf.net/#website",
        "publisher" => { "@id" => "https://givingshelf.net/#organization" },
        "name" => "GivingShelf",
        "url" => base_url,
        "description" => page_description
      }
      
      # Add Service schema for item donation (only for homepage)
      if !defined?(@item) || @item.blank?
        structured_data["@graph"] << {
          "@type" => "Service",
          "name" => "Book and Toy Donation and Sharing Service",
          "description" => "Free book and toy donation and sharing service for local communities. Donate books and toys, discover free items, and share with neighbors.",
          "provider" => {
            "@type" => "Organization",
            "name" => "GivingShelf"
          },
          "areaServed" => {
            "@type" => "Country",
            "name" => "United States"
          },
          "serviceType" => "Book and Toy Donation and Sharing",
          "url" => base_url
        }
      end
    %>
    <%= structured_data.to_json.html_safe %>
    </script>

    <%= stylesheet_link_tag "application-bundled", "data-turbo-track": "reload" %>
    <script>
      window.GivingShelfAppMeta = {
        companyName: "<%= j(GivingShelf::Version::COMPANY_NAME) %>",
        appVersion: "<%= j(GivingShelf::Version::APP_VERSION) %>",
        copyrightYear: "<%= j(GivingShelf::Version.copyright_year) %>"
      };
    </script>
    <%= javascript_include_tag "application-webpack", "data-turbo-track": "reload" %>
    <%# NOTE: This app’s JS is bundled by webpack into app/assets/javascripts/application-webpack.js.
        We intentionally do not load importmap here to avoid double-loading "application". %>
  </head>

  <body>
    <div id="root"></div>
  </body>
</html>
