<h1>Admin Sign In</h1>

<% if flash[:alert] %>
  <div class="alert"><%= flash[:alert] %></div>
<% end %>

<% if flash[:notice] %>
  <div class="notice"><%= flash[:notice] %></div>
<% end %>

<%= form_with url: admin_login_path, local: true do |form| %>
  <div class="field">
    <%= form.label :email, "Email" %>
    <%= form.email_field :email, required: true, autofocus: true, autocomplete: "username", placeholder: "Enter your email address" %>
  </div>

  <div class="field">
    <%= form.label :password, "Password" %>
    <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter your password" %>
  </div>

  <div class="actions">
    <%= form.submit "Sign in" %>
  </div>
<% end %>
